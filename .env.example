# Copy to .env (never commit .env). Compose reads ANTHROPIC_API_KEY from here.

# Optional — enables the Claude agent path. Leave empty to use the offline stub.
ANTHROPIC_API_KEY=

# Defaults below are baked into docker-compose.yml for local dev; override if needed.
# APP_ENV=dev
# AUTH_MODE=dev
# JWT_SECRET=dev-secret-change-me

# --- Microsoft Entra External ID (real auth) ---
# Leave AUTH_MODE=dev for the local stub. To use real Entra login, set
# AUTH_MODE=entra and fill these in (the backend validates tokens against the
# tenant's public JWKS — no client secret needed). The frontend picks up the
# authority/client id automatically from GET /auth/config, so no rebuild.
# AUTH_MODE=entra
# ENTRA_AUTHORITY=https://<tenant>.ciamlogin.com/<tenant-id>/v2.0
# ENTRA_CLIENT_ID=<api-app-registration-client-id>
# ENTRA_AUDIENCE=            # optional; defaults to ENTRA_CLIENT_ID
# ENTRA_ADMIN_ROLE=admin     # app-role value in the token that maps to admin
