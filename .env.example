# Copy to .env (never commit .env). Compose reads these values from here.

# LLM provider (Decision G): pluggable, deepseek is the default. Leave both
# provider keys empty to use the offline stub.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
# Set LLM_PROVIDER=anthropic to use Claude instead.
ANTHROPIC_API_KEY=
# Also doubles as the eval loop's LLM-as-judge key (services/data-agent/agent/eval_judge.py):
# the judge refuses to grade a model of its own family, so it only runs when
# ANTHROPIC_API_KEY is set and LLM_PROVIDER != anthropic. Otherwise `make eval`
# records G3 insight as skipped rather than faking a score.

# Optional — ships agent traces (tool calls, model requests) to Logfire Cloud.
# Leave empty to trace locally only; no code changes needed either way.
LOGFIRE_TOKEN=

# Defaults below are baked into docker-compose.yml for local dev; override if needed.
# APP_ENV=dev
# AUTH_MODE=dev
# JWT_SECRET=dev-secret-change-me

# --- Google Sign-in (real auth) ---
# Leave AUTH_MODE=dev for the local stub. To use real Google login, set
# AUTH_MODE=google and fill these in (the backend validates ID tokens against
# Google's public JWKS — no client secret needed). The frontend picks up the
# client id automatically from GET /auth/config, so no rebuild. The OAuth client
# must be a Web client with http://localhost:5230 as an authorized JS origin.
# AUTH_MODE=google
# GOOGLE_CLIENT_ID=<oauth-2.0-web-client-id>.apps.googleusercontent.com
# ADMIN_EMAILS=you@gmail.com,teammate@gmail.com   # these emails map to the admin role
