!opensrc/setup_opensrc.sh
!opensrc/sources.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/

# Environment / secrets
.env
.env.*
!.env.example

# dbt
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/.user.yml

# raw landing zone — append-only pulls; the committed seed lives in dbt/seeds/
data/raw/

# OS / editor
.DS_Store
